@{
    ViewData["Title"] = "Login";
    Layout = "~/Views/Shared/_LayoutEmpty.cshtml";
}
@section Styles {
    <link rel="stylesheet" href="~/css/login.css" />
}

<div class="login-card">
    <div class="text-center mb-3">
        <i class="fa-solid fa-user-lock fa-2x text-primary"></i>
    </div>

    <h2 class="login-title">Welcome <i class="fa-regular fa-house" style="color: rgb(177, 151, 252);"></i></h2>
    <p class="login-subtitle">Sign in to continue to your dashboard</p>

    <form id="loginForm">
        <div class="mb-3">
            <label class="form-label">Username</label>
            <input id="username" type="text" class="form-control" placeholder="Enter your username" required />
        </div>

        <div class="mb-2">
            <label class="form-label">Password</label>
            <input id="password" type="password" class="form-control" placeholder="Enter your password" required />
        </div>

        <div class="d-flex justify-content-between align-items-center mb-3">
            
            <a href="#" class="text-decoration-none small-link">Forgot password?</a>
        </div>

        <button type="submit" class="btn btn-primary w-100 btn-login">
            Login
        </button>
    </form>

    <div class="text-center mt-3 small-link">
        Don’t have an account?
        @* <a href="#" class="text-decoration-none">Sign up</a> *@
        <a asp-controller="Register" asp-action="Index" class="text-decoration-none">Sign up</a>
    </div>
</div>
@section Scripts {
    <script src="~/js/login.js"></script>
}
