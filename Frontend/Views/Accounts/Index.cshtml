@using Frontend.Models
@model AccountViewModel
@{

}
<div class="container mt-4">
    <h4 class="fw-bold mb-4">IT 01-1</h4>

    <div class="row m-0">
        <div class="col-12 justify-content-end">
            <button type="button" id="btnAddUser" class="btn btn-primary">Add</button>
        </div>
        <div class="row m-0">
            <div class="col-12">
                <table class="table table-bordered table-striped">
                    <thead class="table-dark">
                        <tr>
                            <th>ID</th>
                            <th>ชื่อ - สกุล</th>
                            <th>ที่อยู่</th>
                            <th>วันเกิด</th>
                            <th>อายุ</th>
                            <th class="text-center">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            int idx = 1;
                            var today = DateTime.Now;
                            

                            foreach (var acc in Model.accounts)
                            {
                                var age = today.Year - acc.date_of_birth.Year;

                                if (acc.date_of_birth.Date > today.AddYears(-age))
                                {
                                    age--;
                                }

                                <tr>
                                    <td>@idx</td>
                                    <td>@acc.firstname @acc.lastname</td>
                                    <td>@acc.address</td>
                                    <td>@acc.date_of_birth.ToString("dd-MM-yyyy")</td>
                                    <td>@age</td>
                                    <td class="text-center">
                                        <button class="btn btn-primary btn-sm" id="btnViewUser">View</button>
                                    </td>
                                </tr>

                                idx++;
                            }
                        }

                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>