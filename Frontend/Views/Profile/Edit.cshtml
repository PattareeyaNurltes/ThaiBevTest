@using ClassLib.Enum
@using Frontend.Models
@using System.ComponentModel.DataAnnotations
@model ProfileViewModel
@{
    ViewData["Title"] = "Edit Profile";

    //For Datepicker
    var today = DateTime.Now.ToString("dd-MM-yyyy");
    var minDate = DateTime.Now.AddYears(-100).ToString("dd-MM-yyyy");

    Model.DateOfBirth = Model.DateOfBirth.Year > 2400 ? Model.DateOfBirth.AddYears(-543) : Model.DateOfBirth;
}


<div class="container mt-4">
    <h4 class="fw-bold mb-4">IT 04-1</h4>

    <div id="profileForm">

        <div class="row g-3">

            <div class="col-md-6">
                @Html.LabelFor(m => m.Firstname, new { @class = "form-label" })
                @Html.TextBoxFor(m => m.Firstname, new { @class = "form-control", id = "Firstname", required = "required" })
                @Html.ValidationMessageFor(m => m.Firstname, "", new { @class = "error-box text-danger" ,id = "Firstname-error"})
            </div>

            <div class="col-md-6">
                @Html.LabelFor(m => m.Lastname, new { @class = "form-label" })
                @Html.TextBoxFor(m => m.Lastname, new { @class = "form-control", id = "Lastname", required = "required" })
                @Html.ValidationMessageFor(m => m.Lastname, "", new { @class = "error-box text-danger" ,id = "Lastname-error"})
            </div>

            <div class="col-md-6">
                @Html.LabelFor(m => m.Email, new { @class = "form-label" })
                @Html.TextBoxFor(m => m.Email, new { @class = "form-control", id = "Email", required = "required" })
                @Html.ValidationMessageFor(m => m.Email, "", new { @class = "error-box text-danger" ,id = "Email-error"})
            </div>

            <div class="col-md-6">
                @Html.LabelFor(m => m.Phone_No, new { @class = "form-label" })
                @Html.TextBoxFor(m => m.Phone_No, new { @class = "form-control", id = "Phone_No", required = "required" })
                @Html.ValidationMessageFor(m => m.Phone_No, "", new { @class = "error-box text-danger" ,id = "Phone_No-error"})
            </div>

            <div class="col-md-6">
                @Html.LabelFor(m => m.Profile_Image, "Profile", new { @class = "form-label" })
                <input type="file" id="Profile_Image" class="form-control" required/>
                @Html.ValidationMessageFor(m => m.Profile_Image, "", new { @class = "error-box text-danger",id = "Profile_Image-error" })

                <!-- Preview Box -->
                @if(!string.IsNullOrEmpty(Model.Profile_Image)){
                        <img id="previewImage"
                         src="@Model.Profile_Image"
                         class="img-thumbnail mb-2"
                         style="width: 150px; height: 150px; object-fit: cover;" />
                }
            </div>

            <div class="col-md-6">
                @Html.LabelFor(m => m.DateOfBirth, new { @class = "form-label" })
                <input type="text" id="DateOfBirth" class="form-control" value="@Model.DateOfBirth.ToString("dd-MM-yyyy")"/>
                @Html.ValidationMessageFor(m => m.DateOfBirth, "", new { @class = "error-box text-danger", id = "DateOfBirth-error" })

            </div>

            <div class="col-md-6">
                @Html.LabelFor(m => m.Occupation, new { @class = "form-label" })
                @{
                    var items = Enum.GetValues(typeof(Occupation))
                    .Cast<Occupation>()
                    .Select(o => new
                    {
                        Value = o.ToString(),
                        Text = o.GetType()
                    .GetMember(o.ToString())[0]
                    .GetCustomAttributes(typeof(DisplayAttribute), false)
                    .Cast<DisplayAttribute>()
                    .FirstOrDefault()?.Name ?? o.ToString()
                    });
                }

                @Html.DropDownListFor(
                m => m.Occupation,
                                new SelectList(items, "Value", "Text"),
                                "-- Select Occupation --",
                                new { @class = "form-select", id = "Occupation" })
                @Html.ValidationMessageFor(m => m.Occupation, "", new { @class = "error-box text-danger" ,id = "Occupation-error"})
            </div>

            <div class="col-md-6">
                <label class="form-label">Gender</label>

                <div class="d-flex gap-3">

                   @foreach (var item in Enum.GetValues(typeof(Genders)).Cast<Genders>().Select((g, index) => new { g, index }))
                    {
                        var id = "gender_" + item.index;

                        <div class="form-check">
                            <input type="radio"
                                   name="Gender"
                                   value="@item.index.ToString()"
                                   class="form-check-input"
                                   id="@id"
                                   @(Model.Gender == item.index.ToString() ? "checked" : "")/>

                            <label class="form-check-label" for="@id">@item.g</label>
                        </div>
                    }
                    @Html.ValidationMessageFor(m => m.Gender, "", new { @class = "error-box text-danger" ,id = "Gender-error"})

                </div>
            </div>


        </div>

        <div class="mt-4 d-flex gap-2">
            <button type="button" id="btnSave" class="btn btn-success px-4" onclick="submitProfile()">Save</button>
            <button type="reset" id="btnCancel" class="btn btn-secondary px-4" onclick="clearProfile()">Clear</button>
        </div>

    </div>
</div>
@section Scripts {
    <script src="~/js/ProfileEdit.js"></script>
}

